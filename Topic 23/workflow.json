    {
      "parameters": {
        "jsCode": "// n8n Code Node\n// Cleans and standardizes AI classification output\n\nconst cleaned = [];\n\nfor (const item of items) {\n  try {\n    // Parse if AI returned JSON as string\n    let output = item.json.output || item.json;\n    \n    if (typeof output === 'string') {\n      output = JSON.parse(output);\n    }\n    \n    // Add the cleaned, flattened object to our results array\n    cleaned.push({\n      json: {\n        linkedin_url: output.linkedin_url || '',\n        name: output.name || '',\n        headline: output.headline || '',\n        location: output.location || '',\n        category: output.category || ''\n      }\n    });\n    \n  } catch (error) {\n    // Fallback if parsing fails to avoid crashing the whole loop\n    cleaned.push({\n      json: {\n        error: \"Failed to parse AI output\",\n        raw: item.json.output\n      }\n    });\n  }\n}\n\nreturn cleaned;"
      },
