    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Step 1: Extract and Normalize Stage\nconst stage = item.json.stage;\nlet funnelStatus = 'Unknown';\n\nif (stage) {\n  switch (String(stage).toLowerCase().trim()) {\n    case 'suspect interested':\n    case 'suspect not interested':\n    case 'lead not responding':\n    case 'webinar registration completed':\n    case 'webinar attended':\n    case 'after webinar registration didn\\'t attend':\n      funnelStatus = 'Lead';\n      break;\n    case 'mql':\n      funnelStatus = 'MQL';\n      break;\n    case 'sql':\n      funnelStatus = 'SQL';\n      break;\n    case 'customer':\n    case 'won':\n      funnelStatus = 'Customer';\n      break;\n  }\n}\n\n// Step 2: Implement Duplicate/Idempotency Detection\n// Skip processing if status_funnel is already matching current calculation\nif (item.json.status_funnel === funnelStatus) {\n  item.json.is_duplicate = true;\n} else {\n  item.json.is_duplicate = false;\n  item.json.status_funnel = funnelStatus;\n}\n\nreturn item;"
      },
