      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, customer_name, stage, status_funnel \nFROM public.opportunity \nWHERE status_funnel IS NULL;",
        "options": {}
      },
      "id": "33743bb1-000f-4eca-8e19-ab5f110bdc15",
