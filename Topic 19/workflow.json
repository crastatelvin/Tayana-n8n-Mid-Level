    {
      "parameters": {
        "jsCode": "const item = $input.item;\nconst aiResponse = item.json.output || \"\";\n\nconst originalRow = $('Loop Over Items').item.json;\n\nlet partnerStatus = \"No\";\nlet evidence = \"Could not parse AI response cleanly.\";\n\nconst partnerMatch = aiResponse.match(/Partner Confirmation:\\s*(Yes|No)/i);\nconst reasoningMatch = aiResponse.match(/Reasoning:\\s*([\\s\\S]+)/i);\n\nif (partnerMatch && partnerMatch[1]) {\n    partnerStatus = partnerMatch[1].trim();\n}\n\nif (reasoningMatch && reasoningMatch[1]) {\n    evidence = reasoningMatch[1].trim();\n}\n\nreturn {\n    json: {\n        record_id: originalRow.ID || \"N/A\",\n        company_name: originalRow[\"COMPANY NAME\"] || \"Unknown\",\n        partner_confirmation: partnerStatus,\n        audit_evidence: evidence,\n        status: \"Processed\",\n        timestamp: new Date().toISOString().split('T')[0]\n    }\n};"
      },
