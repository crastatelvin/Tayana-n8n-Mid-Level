      "parameters": {
        "jsCode": "return items.map(item => {\n\n  let url = item.json.profile_url || \"\";\n\n  url = url\n    .toLowerCase()\n    .trim()\n    .replace('https://', '')\n    .replace('http://', '')\n    .replace('www.', '')\n    .replace(/\\/$/, '');\n\n  item.json.normalized_url = url;\n\n  return item;\n});"
