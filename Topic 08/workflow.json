      "parameters": {
        "jsCode": "const posts = items;\n\nconst totalPosts = posts.length;\n\nconst totalLikes = posts.reduce((sum, post) => {\n  return sum + (post.json.likesCount || 0);\n}, 0);\n\nconst avgLikes = totalPosts > 0 ? totalLikes / totalPosts : 0;\n\nreturn [{\n  json: {\n    record_id: $('Normalize URL').first().json.record_id,\n    profile_url: $('Normalize URL').first().json.profile_url,\n    normalized_url: $('Normalize URL').first().json.normalized_url,\n    total_posts: totalPosts,\n    total_likes: totalLikes,\n    average_likes: avgLikes,\n    processed_at: new Date().toISOString(),\n    status: 'completed'\n  }\n}];"
      },
